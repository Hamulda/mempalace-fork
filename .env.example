# MemPalace Configuration
# Copy to .env and customize as needed

# Transport: "stdio" (local, default) or "http" (remote)
MEMPALACE_TRANSPORT=stdio

# HTTP transport settings (only used when TRANSPORT=http)
MEMPALACE_HOST=127.0.0.1
MEMPALACE_PORT=8765

# Database settings
MEMPALACE_DB_PATH=~/.mempalace/palace
MEMPALACE_DB_BACKEND=chromadb

# Response caching TTL (seconds)
MEMPALACE_CACHE_TTL_STATUS=5
MEMPALACE_CACHE_TTL_METADATA=30

# Embedding circuit breaker settings
MEMPALACE_CB_FAILURE_THRESHOLD=5
MEMPALACE_CB_RECOVERY_TIMEOUT=30

# Response size limit (bytes)
MEMPALACE_MAX_RESPONSE_SIZE=500000

# Debug logging
MEMPALACE_LOG_PAYLOADS=false
MEMPALACE_LOG_SESSIONS=false
